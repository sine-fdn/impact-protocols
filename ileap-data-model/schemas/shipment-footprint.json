{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ShipmentFootprint",
  "type": "object",
  "required": [
    "mass",
    "shipmentId",
    "tces"
  ],
  "properties": {
    "comment": {
      "description": "Additional comment. O",
      "type": [
        "string",
        "null"
      ]
    },
    "companyIds": {
      "description": "Set of identifiers for the data owner company. O",
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "string"
      }
    },
    "companyName": {
      "description": "Name of the company owning the data. M*",
      "type": [
        "string",
        "null"
      ]
    },
    "createdAt": {
      "description": "Creation timestamp of this ShipmentFootprint. M*",
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "description": {
      "description": "Description of the Shipment. O",
      "type": [
        "string",
        "null"
      ]
    },
    "mass": {
      "type": "string"
    },
    "pactPds": {
      "description": "Primary data share (0–100). O",
      "anyOf": [
        {
          "$ref": "#/definitions/PercentDecimal"
        },
        {
          "type": "null"
        }
      ]
    },
    "referencePeriodEnd": {
      "description": "Reference period end (exclusive). M*",
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "referencePeriodStart": {
      "description": "Reference period start (inclusive). M*",
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "secondaryEmissionFactorSources": {
      "description": "Secondary emission factor sources used. O",
      "type": [
        "array",
        "null"
      ],
      "items": {
        "$ref": "#/definitions/SecondaryEmissionFactorSource"
      }
    },
    "shipmentId": {
      "type": "string"
    },
    "specVersion": {
      "description": "iLEAP spec version; MUST be \"1.1.0\". M* (mandatory when exchanged via standalone protocol)",
      "type": [
        "string",
        "null"
      ]
    },
    "status": {
      "description": "Status of this ShipmentFootprint. M (always required). Defaults to `Active` when deserializing pre-v1.1 data that omits this field.",
      "default": "Active",
      "allOf": [
        {
          "$ref": "#/definitions/Status"
        }
      ]
    },
    "tces": {
      "$ref": "#/definitions/NonEmptyVec_for_TCE"
    },
    "volume": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "definitions": {
    "Decimal": {
      "type": "string",
      "pattern": "^-?\\d+(\\.\\d+)?$"
    },
    "GlecDistance": {
      "type": "object",
      "anyOf": [
        {
          "type": "object",
          "required": [
            "actual"
          ],
          "properties": {
            "actual": {
              "$ref": "#/definitions/Decimal"
            },
            "gcd": {
              "anyOf": [
                {
                  "$ref": "#/definitions/Decimal"
                },
                {
                  "type": "null"
                }
              ]
            },
            "sfd": {
              "anyOf": [
                {
                  "$ref": "#/definitions/Decimal"
                },
                {
                  "type": "null"
                }
              ]
            }
          }
        },
        {
          "type": "object",
          "required": [
            "gcd"
          ],
          "properties": {
            "actual": {
              "anyOf": [
                {
                  "$ref": "#/definitions/Decimal"
                },
                {
                  "type": "null"
                }
              ]
            },
            "gcd": {
              "$ref": "#/definitions/Decimal"
            },
            "sfd": {
              "anyOf": [
                {
                  "$ref": "#/definitions/Decimal"
                },
                {
                  "type": "null"
                }
              ]
            }
          }
        },
        {
          "type": "object",
          "required": [
            "sfd"
          ],
          "properties": {
            "actual": {
              "anyOf": [
                {
                  "$ref": "#/definitions/Decimal"
                },
                {
                  "type": "null"
                }
              ]
            },
            "gcd": {
              "anyOf": [
                {
                  "$ref": "#/definitions/Decimal"
                },
                {
                  "type": "null"
                }
              ]
            },
            "sfd": {
              "$ref": "#/definitions/Decimal"
            }
          }
        }
      ]
    },
    "ISO3166CC": {
      "type": "string",
      "pattern": "^[A-Z]{2}$"
    },
    "IataCode": {
      "type": "string"
    },
    "Incoterms": {
      "type": "string",
      "enum": [
        "EXW",
        "FCA",
        "CPT",
        "CIP",
        "DAP",
        "DPU",
        "DDP",
        "FAS",
        "FOB",
        "CFR",
        "CIF"
      ]
    },
    "Location": {
      "type": "object",
      "required": [
        "city",
        "country"
      ],
      "properties": {
        "city": {
          "type": "string"
        },
        "country": {
          "$ref": "#/definitions/ISO3166CC"
        },
        "iata": {
          "anyOf": [
            {
              "$ref": "#/definitions/IataCode"
            },
            {
              "type": "null"
            }
          ]
        },
        "lat": {
          "anyOf": [
            {
              "$ref": "#/definitions/Decimal"
            },
            {
              "type": "null"
            }
          ]
        },
        "lng": {
          "anyOf": [
            {
              "$ref": "#/definitions/Decimal"
            },
            {
              "type": "null"
            }
          ]
        },
        "locode": {
          "anyOf": [
            {
              "$ref": "#/definitions/Locode"
            },
            {
              "type": "null"
            }
          ]
        },
        "street": {
          "type": [
            "string",
            "null"
          ]
        },
        "uic": {
          "anyOf": [
            {
              "$ref": "#/definitions/UicCode"
            },
            {
              "type": "null"
            }
          ]
        },
        "zip": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "Locode": {
      "type": "string"
    },
    "NonEmptyVec_for_TCE": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/TCE"
      }
    },
    "PackagingOrTrEqType": {
      "type": "string",
      "enum": [
        "Box",
        "Pallet",
        "Container-TEU",
        "Container-FEU",
        "Container"
      ]
    },
    "PercentDecimal": {
      "type": "string"
    },
    "PositiveDecimal": {
      "type": "string",
      "pattern": "^\\d+(\\.\\d+)?$"
    },
    "SecondaryEmissionFactorSource": {
      "description": "Secondary emission factor source, referencing a named data source and optional version.",
      "type": "object",
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "version": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "Status": {
      "description": "Status of an iLEAP data object (ShipmentFootprint, TOC, HOC, AggregatedReport). Mandatory for all exchanges (both standalone and PACT-based). Defaults to `Active` for backwards-compatible deserialization of pre-v1.1 data.",
      "type": "string",
      "enum": [
        "Active",
        "Deprecated"
      ]
    },
    "TCE": {
      "type": "object",
      "required": [
        "co2eTTW",
        "co2eWTW",
        "distance",
        "mass",
        "shipmentId",
        "tceId",
        "transportActivity"
      ],
      "properties": {
        "arrivalAt": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "ch4TTW": {
          "anyOf": [
            {
              "$ref": "#/definitions/Decimal"
            },
            {
              "type": "null"
            }
          ]
        },
        "co2eTTW": {
          "$ref": "#/definitions/Decimal"
        },
        "co2eWTW": {
          "$ref": "#/definitions/Decimal"
        },
        "consignmentId": {
          "type": [
            "string",
            "null"
          ]
        },
        "departureAt": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "destination": {
          "anyOf": [
            {
              "$ref": "#/definitions/Location"
            },
            {
              "type": "null"
            }
          ]
        },
        "distance": {
          "$ref": "#/definitions/GlecDistance"
        },
        "flightNo": {
          "type": [
            "string",
            "null"
          ]
        },
        "hocId": {
          "type": [
            "string",
            "null"
          ]
        },
        "incoterms": {
          "anyOf": [
            {
              "$ref": "#/definitions/Incoterms"
            },
            {
              "type": "null"
            }
          ]
        },
        "mass": {
          "$ref": "#/definitions/Decimal"
        },
        "noxTTW": {
          "anyOf": [
            {
              "$ref": "#/definitions/Decimal"
            },
            {
              "type": "null"
            }
          ]
        },
        "origin": {
          "anyOf": [
            {
              "$ref": "#/definitions/Location"
            },
            {
              "type": "null"
            }
          ]
        },
        "packagingOrTrEqAmount": {
          "anyOf": [
            {
              "$ref": "#/definitions/PositiveDecimal"
            },
            {
              "type": "null"
            }
          ]
        },
        "packagingOrTrEqType": {
          "anyOf": [
            {
              "$ref": "#/definitions/PackagingOrTrEqType"
            },
            {
              "type": "null"
            }
          ]
        },
        "pmTTW": {
          "anyOf": [
            {
              "$ref": "#/definitions/Decimal"
            },
            {
              "type": "null"
            }
          ]
        },
        "prevTceIds": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string"
          }
        },
        "shipmentId": {
          "type": "string"
        },
        "soxTTW": {
          "anyOf": [
            {
              "$ref": "#/definitions/Decimal"
            },
            {
              "type": "null"
            }
          ]
        },
        "tceId": {
          "type": "string"
        },
        "tocId": {
          "type": [
            "string",
            "null"
          ]
        },
        "transportActivity": {
          "$ref": "#/definitions/Decimal"
        },
        "voyageNo": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "UicCode": {
      "type": "string"
    }
  }
}