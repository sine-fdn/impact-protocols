{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TOC",
  "type": "object",
  "required": [
    "co2eIntensityTTW",
    "co2eIntensityWTW",
    "energyCarriers",
    "mode",
    "tocId",
    "transportActivityUnit"
  ],
  "properties": {
    "specVersion": {
      "description": "iLEAP spec version; MUST be \"1.1.0\". M*",
      "type": [
        "string",
        "null"
      ]
    },
    "companyName": {
      "description": "Name of the company owning the data. M*",
      "type": [
        "string",
        "null"
      ]
    },
    "companyIds": {
      "description": "Set of identifiers for the data owner company. O",
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "string"
      }
    },
    "createdAt": {
      "description": "Creation timestamp. M*",
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "status": {
      "description": "Status of this TOC. M (always required). Defaults to `Active` when deserializing pre-v1.1 data that omits this field.",
      "default": "Active",
      "allOf": [
        {
          "$ref": "#/definitions/ILeapStatus"
        }
      ]
    },
    "referencePeriodStart": {
      "description": "Reference period start (inclusive). M*",
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "referencePeriodEnd": {
      "description": "Reference period end (exclusive). M*",
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "secondaryEmissionFactorSources": {
      "description": "Secondary emission factor sources. O TODO: proposed attribute pending community input (spec Issue tag)",
      "type": [
        "array",
        "null"
      ],
      "items": {
        "$ref": "#/definitions/SecondaryEmissionFactorSource"
      }
    },
    "pactPds": {
      "description": "Primary data share (0–100). O TODO: proposed attribute pending community input (spec Issue tag)",
      "anyOf": [
        {
          "$ref": "#/definitions/Decimal"
        },
        {
          "type": "null"
        }
      ]
    },
    "comment": {
      "description": "Additional comment. O TODO: proposed attribute pending community input (spec Issue tag)",
      "type": [
        "string",
        "null"
      ]
    },
    "tocId": {
      "type": "string"
    },
    "certifications": {
      "anyOf": [
        {
          "$ref": "#/definitions/NonEmptyVec_for_Certification"
        },
        {
          "type": "null"
        }
      ]
    },
    "description": {
      "type": [
        "string",
        "null"
      ]
    },
    "mode": {
      "$ref": "#/definitions/TransportMode"
    },
    "loadFactor": {
      "type": [
        "string",
        "null"
      ]
    },
    "emptyDistanceFactor": {
      "type": [
        "string",
        "null"
      ]
    },
    "temperatureControl": {
      "anyOf": [
        {
          "$ref": "#/definitions/TemperatureControl"
        },
        {
          "type": "null"
        }
      ]
    },
    "truckLoadingSequence": {
      "anyOf": [
        {
          "$ref": "#/definitions/TruckLoadingSequence"
        },
        {
          "type": "null"
        }
      ]
    },
    "airShippingOption": {
      "anyOf": [
        {
          "$ref": "#/definitions/AirShippingOption"
        },
        {
          "type": "null"
        }
      ]
    },
    "flightLength": {
      "anyOf": [
        {
          "$ref": "#/definitions/FlightLength"
        },
        {
          "type": "null"
        }
      ]
    },
    "energyCarriers": {
      "$ref": "#/definitions/NonEmptyVec_for_EnergyCarrier"
    },
    "co2eIntensityWTW": {
      "$ref": "#/definitions/Decimal"
    },
    "co2eIntensityTTW": {
      "$ref": "#/definitions/Decimal"
    },
    "transportActivityUnit": {
      "$ref": "#/definitions/TransportActivityUnit"
    }
  },
  "definitions": {
    "ILeapStatus": {
      "description": "Status of an iLEAP data object (ShipmentFootprint, TOC, HOC, AggregatedReport). Mandatory for all exchanges (both standalone and PACT-based). Defaults to `Active` for backwards-compatible deserialization of pre-v1.1 data.",
      "type": "string",
      "enum": [
        "Active",
        "Deprecated"
      ]
    },
    "SecondaryEmissionFactorSource": {
      "description": "Secondary emission factor source, referencing a named data source and optional version.",
      "type": "object",
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "version": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "Decimal": {
      "type": "string",
      "pattern": "^-?\\d+(\\.\\d+)?$"
    },
    "NonEmptyVec_for_Certification": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/Certification"
      }
    },
    "Certification": {
      "type": "string",
      "enum": [
        "ISO14083:2023",
        "GLECv2",
        "GLECv3",
        "GLECv3.1"
      ]
    },
    "TransportMode": {
      "type": "string",
      "enum": [
        "Road",
        "Rail",
        "Air",
        "Sea",
        "InlandWaterway"
      ]
    },
    "TemperatureControl": {
      "type": "string",
      "enum": [
        "ambient",
        "refrigerated",
        "mixed"
      ]
    },
    "TruckLoadingSequence": {
      "type": "string",
      "enum": [
        "LTL",
        "FTL"
      ]
    },
    "AirShippingOption": {
      "type": "string",
      "enum": [
        "belly freight",
        "freighter"
      ]
    },
    "FlightLength": {
      "type": "string",
      "enum": [
        "short-haul",
        "long-haul"
      ]
    },
    "NonEmptyVec_for_EnergyCarrier": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/EnergyCarrier"
      }
    },
    "EnergyCarrier": {
      "type": "object",
      "required": [
        "emissionFactorTTW",
        "emissionFactorWTW",
        "energyCarrier",
        "relativeShare"
      ],
      "properties": {
        "energyCarrier": {
          "$ref": "#/definitions/EnergyCarrierType"
        },
        "feedstocks": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "$ref": "#/definitions/Feedstock"
          }
        },
        "energyConsumption": {
          "anyOf": [
            {
              "$ref": "#/definitions/Decimal"
            },
            {
              "type": "null"
            }
          ]
        },
        "energyConsumptionUnit": {
          "anyOf": [
            {
              "$ref": "#/definitions/EnergyConsumptionUnit"
            },
            {
              "type": "null"
            }
          ]
        },
        "emissionFactorWTW": {
          "description": "TODO: The spec defines emissionFactorWTW and emissionFactorTTW as O at the field level, but states they MUST be defined when EnergyCarrier is used in the context of a TOC or HOC. Currently kept as required (WrappedDecimal) for simplicity. Consider making them Option<> and validating at the application layer based on context.",
          "allOf": [
            {
              "$ref": "#/definitions/Decimal"
            }
          ]
        },
        "emissionFactorTTW": {
          "$ref": "#/definitions/Decimal"
        },
        "relativeShare": {
          "$ref": "#/definitions/Decimal"
        }
      }
    },
    "EnergyCarrierType": {
      "type": "string",
      "enum": [
        "Diesel",
        "HVO",
        "Petrol",
        "CNG",
        "LNG",
        "LPG",
        "HFO",
        "MGO",
        "Aviation fuel",
        "Hydrogen",
        "Methanol",
        "Electric"
      ]
    },
    "Feedstock": {
      "type": "object",
      "required": [
        "feedstock"
      ],
      "properties": {
        "feedstock": {
          "$ref": "#/definitions/FeedstockType"
        },
        "feedstockShare": {
          "anyOf": [
            {
              "$ref": "#/definitions/Decimal"
            },
            {
              "type": "null"
            }
          ]
        },
        "regionProvenance": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "FeedstockType": {
      "type": "string",
      "enum": [
        "Fossil",
        "Natural gas",
        "Grid",
        "Renewable electricity",
        "Cooking oil"
      ]
    },
    "EnergyConsumptionUnit": {
      "type": "string",
      "enum": [
        "l",
        "kg",
        "kWh",
        "MJ"
      ]
    },
    "TransportActivityUnit": {
      "type": "string",
      "enum": [
        "TEUkm",
        "tkm"
      ]
    }
  }
}