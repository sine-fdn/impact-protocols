{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "HOC",
  "type": "object",
  "required": [
    "co2eIntensityTTW",
    "co2eIntensityWTW",
    "energyCarriers",
    "hocId",
    "hubActivityUnit",
    "hubType"
  ],
  "properties": {
    "certifications": {
      "anyOf": [
        {
          "$ref": "#/definitions/NonEmptyVec_for_Certification"
        },
        {
          "type": "null"
        }
      ]
    },
    "co2eIntensityTTW": {
      "$ref": "#/definitions/Decimal"
    },
    "co2eIntensityWTW": {
      "$ref": "#/definitions/Decimal"
    },
    "comment": {
      "description": "Additional comment. O",
      "type": [
        "string",
        "null"
      ]
    },
    "companyIds": {
      "description": "Set of identifiers for the data owner company. O",
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "string"
      }
    },
    "companyName": {
      "description": "Name of the company owning the data. M*",
      "type": [
        "string",
        "null"
      ]
    },
    "createdAt": {
      "description": "Creation timestamp. M*",
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "description": {
      "type": [
        "string",
        "null"
      ]
    },
    "energyCarriers": {
      "$ref": "#/definitions/NonEmptyVec_for_EnergyCarrier"
    },
    "hocId": {
      "type": "string"
    },
    "hubActivityUnit": {
      "$ref": "#/definitions/HubActivityUnit"
    },
    "hubLocation": {
      "anyOf": [
        {
          "$ref": "#/definitions/Location"
        },
        {
          "type": "null"
        }
      ]
    },
    "hubType": {
      "$ref": "#/definitions/HubType"
    },
    "inboundTransportMode": {
      "anyOf": [
        {
          "$ref": "#/definitions/TransportMode"
        },
        {
          "type": "null"
        }
      ]
    },
    "outboundTransportMode": {
      "anyOf": [
        {
          "$ref": "#/definitions/TransportMode"
        },
        {
          "type": "null"
        }
      ]
    },
    "packagingOrTrEqAmount": {
      "type": [
        "integer",
        "null"
      ],
      "format": "uint",
      "minimum": 0.0
    },
    "packagingOrTrEqType": {
      "anyOf": [
        {
          "$ref": "#/definitions/PackagingOrTrEqType"
        },
        {
          "type": "null"
        }
      ]
    },
    "pactPds": {
      "description": "Primary data share (0–100). O",
      "anyOf": [
        {
          "$ref": "#/definitions/PercentDecimal"
        },
        {
          "type": "null"
        }
      ]
    },
    "referencePeriodEnd": {
      "description": "Reference period end (exclusive). M*",
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "referencePeriodStart": {
      "description": "Reference period start (inclusive). M*",
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "secondaryEmissionFactorSources": {
      "description": "Secondary emission factor sources. O",
      "type": [
        "array",
        "null"
      ],
      "items": {
        "$ref": "#/definitions/SecondaryEmissionFactorSource"
      }
    },
    "specVersion": {
      "description": "iLEAP spec version; MUST be \"1.1.0\". M*",
      "type": [
        "string",
        "null"
      ]
    },
    "status": {
      "description": "Status of this HOC. M (always required). Defaults to `Active` when deserializing pre-v1.1 data that omits this field.",
      "default": "Active",
      "allOf": [
        {
          "$ref": "#/definitions/Status"
        }
      ]
    },
    "temperatureControl": {
      "anyOf": [
        {
          "$ref": "#/definitions/TemperatureControl"
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "definitions": {
    "Certification": {
      "type": "string",
      "enum": [
        "ISO14083:2023",
        "GLECv2",
        "GLECv3",
        "GLECv3.1"
      ]
    },
    "Decimal": {
      "type": "string",
      "pattern": "^-?\\d+(\\.\\d+)?$"
    },
    "EnergyCarrier": {
      "type": "object",
      "required": [
        "energyCarrier",
        "relativeShare"
      ],
      "properties": {
        "emissionFactorTTW": {
          "description": "kgCO2e per `energyConsumptionUnit`. Optional at field level per spec §6.7.7, but MUST be defined when `EnergyCarrier` is used in the context of a TOC or HOC. May be omitted for TAD usage where emission factors are not yet known.",
          "anyOf": [
            {
              "$ref": "#/definitions/Decimal"
            },
            {
              "type": "null"
            }
          ]
        },
        "emissionFactorWTW": {
          "description": "kgCO2e per `energyConsumptionUnit`. Optional at field level per spec §6.7.7, but MUST be defined when `EnergyCarrier` is used in the context of a TOC or HOC. May be omitted for TAD usage where emission factors are not yet known.",
          "anyOf": [
            {
              "$ref": "#/definitions/Decimal"
            },
            {
              "type": "null"
            }
          ]
        },
        "energyCarrier": {
          "$ref": "#/definitions/EnergyCarrierType"
        },
        "energyConsumption": {
          "anyOf": [
            {
              "$ref": "#/definitions/Decimal"
            },
            {
              "type": "null"
            }
          ]
        },
        "energyConsumptionUnit": {
          "anyOf": [
            {
              "$ref": "#/definitions/EnergyConsumptionUnit"
            },
            {
              "type": "null"
            }
          ]
        },
        "feedstocks": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "$ref": "#/definitions/Feedstock"
          }
        },
        "relativeShare": {
          "$ref": "#/definitions/Decimal"
        }
      }
    },
    "EnergyCarrierType": {
      "type": "string",
      "enum": [
        "Diesel",
        "HVO",
        "Petrol",
        "CNG",
        "LNG",
        "LPG",
        "HFO",
        "MGO",
        "Aviation fuel",
        "Hydrogen",
        "Methanol",
        "Electric"
      ]
    },
    "EnergyConsumptionUnit": {
      "type": "string",
      "enum": [
        "l",
        "kg",
        "kWh",
        "MJ"
      ]
    },
    "Feedstock": {
      "type": "object",
      "required": [
        "feedstock"
      ],
      "properties": {
        "feedstock": {
          "$ref": "#/definitions/FeedstockType"
        },
        "feedstockShare": {
          "anyOf": [
            {
              "$ref": "#/definitions/Decimal"
            },
            {
              "type": "null"
            }
          ]
        },
        "regionProvenance": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "FeedstockType": {
      "type": "string",
      "enum": [
        "Fossil",
        "Natural gas",
        "Grid",
        "Renewable electricity",
        "Cooking oil"
      ]
    },
    "HubActivityUnit": {
      "type": "string",
      "enum": [
        "TEU",
        "tonnes"
      ]
    },
    "HubType": {
      "type": "string",
      "enum": [
        "Transshipment",
        "StorageAndTransshipment",
        "Warehouse",
        "LiquidBulkTerminal",
        "MaritimeContainerTerminal"
      ]
    },
    "ISO3166CC": {
      "type": "string",
      "pattern": "^[A-Z]{2}$"
    },
    "IataCode": {
      "type": "string"
    },
    "Location": {
      "type": "object",
      "required": [
        "city",
        "country"
      ],
      "properties": {
        "city": {
          "type": "string"
        },
        "country": {
          "$ref": "#/definitions/ISO3166CC"
        },
        "iata": {
          "anyOf": [
            {
              "$ref": "#/definitions/IataCode"
            },
            {
              "type": "null"
            }
          ]
        },
        "lat": {
          "anyOf": [
            {
              "$ref": "#/definitions/Decimal"
            },
            {
              "type": "null"
            }
          ]
        },
        "lng": {
          "anyOf": [
            {
              "$ref": "#/definitions/Decimal"
            },
            {
              "type": "null"
            }
          ]
        },
        "locode": {
          "anyOf": [
            {
              "$ref": "#/definitions/Locode"
            },
            {
              "type": "null"
            }
          ]
        },
        "street": {
          "type": [
            "string",
            "null"
          ]
        },
        "uic": {
          "anyOf": [
            {
              "$ref": "#/definitions/UicCode"
            },
            {
              "type": "null"
            }
          ]
        },
        "zip": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "Locode": {
      "type": "string"
    },
    "NonEmptyVec_for_Certification": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/Certification"
      }
    },
    "NonEmptyVec_for_EnergyCarrier": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/EnergyCarrier"
      }
    },
    "PackagingOrTrEqType": {
      "type": "string",
      "enum": [
        "Box",
        "Pallet",
        "Container-TEU",
        "Container-FEU",
        "Container"
      ]
    },
    "PercentDecimal": {
      "type": "string"
    },
    "SecondaryEmissionFactorSource": {
      "description": "Secondary emission factor source, referencing a named data source and optional version.",
      "type": "object",
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "version": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "Status": {
      "description": "Status of an iLEAP data object (ShipmentFootprint, TOC, HOC, AggregatedReport). Mandatory for all exchanges (both standalone and PACT-based). Defaults to `Active` for backwards-compatible deserialization of pre-v1.1 data.",
      "type": "string",
      "enum": [
        "Active",
        "Deprecated"
      ]
    },
    "TemperatureControl": {
      "type": "string",
      "enum": [
        "ambient",
        "refrigerated",
        "mixed"
      ]
    },
    "TransportMode": {
      "type": "string",
      "enum": [
        "Road",
        "Rail",
        "Air",
        "Sea",
        "InlandWaterway"
      ]
    },
    "UicCode": {
      "type": "string"
    }
  }
}